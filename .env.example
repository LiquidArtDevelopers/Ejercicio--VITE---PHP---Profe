# Desarrollo: PHP en localhost:3000 y Vite en localhost:5173.
APP_ENV=development
RUTA=http://localhost:5173

# Preview: usar cuando pruebes el build con npm run preview.
# APP_ENV=preview
# RUTA=http://localhost:4173

# Produccion: cambia el dominio por el definitivo y descomenta estas lineas.
# APP_ENV=production
# RUTA=https://www.ejemplo.com

# Idioma por defecto: / redirige a /es si vale es.
LANG_DEFAULT=es
# LANG_DEFAULT=eu
